# =============================================================
# DocGen — contoh environment (salin ke .env, isi nilainya)
# Loader (packages/config) memvalidasi semua ini SEKALI saat start
# dengan Zod dan GAGAL CEPAT bila ada yang kurang/salah (docs/21).
# Jangan commit .env yang berisi rahasia asli (docs/13).
# =============================================================

# Lingkungan: development | test | production
NODE_ENV=development

# --- Database & antrian ---------------------------------------
# Cocok dengan layanan di docker-compose.yml.
# Postgres dipetakan ke host :5433 (lihat compose) agar tidak bentrok dengan
# Postgres lain di :5432. Redis :6379; bila bentrok, ubah compose ke 6380:6379.
DATABASE_URL=postgresql://docgen:docgen@localhost:5433/docgen
REDIS_URL=redis://localhost:6379

# --- API service ----------------------------------------------
API_HOST=0.0.0.0
# 3000 sering dipakai dev server lain; pakai 3001 untuk API DocGen.
API_PORT=3001
LOG_LEVEL=info
# URL publik dasar (dipakai untuk membentuk tautan absolut).
PUBLIC_BASE_URL=http://localhost:3001

# --- Penyimpanan objek (R2/S3/MinIO) --------------------------
# Untuk dev lokal pakai driver=filesystem (tanpa MinIO).
# Untuk produksi Cloudflare R2, isi nilai di bawah dan set STORAGE_DRIVER=s3:
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_REGION=auto
#   STORAGE_ACCESS_KEY=<R2 Access Key ID>
#   STORAGE_SECRET_KEY=<R2 Secret Access Key>
#   STORAGE_BUCKET=<nama bucket R2>
#   STORAGE_FORCE_PATH_STYLE=false
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=docgen
STORAGE_SECRET_KEY=docgen-secret
STORAGE_BUCKET=docgen-files
# MinIO/path-style butuh ini true; S3/R2 pakai false.
STORAGE_FORCE_PATH_STYLE=true
# Driver storage: filesystem (dev lokal) | s3 (R2/S3/MinIO produksi).
STORAGE_DRIVER=filesystem
# Folder PDF lokal saat driver=filesystem.
STORAGE_DIR=./var/storage
# Umur tautan unduh bertanda tangan (detik).
SIGNED_URL_TTL_SECONDS=900

# --- Render (Tahap 4) ---------------------------------------
RENDER_TIMEOUT_MS=30000
RENDER_CONCURRENCY=2

# --- Kasugai payment gateway (proxy Midtrans) -----------------
# Top-up kredit lewat Kasugai. Ambil key dari dashboard kasugai.razornez.net.
KASUGAI_BASE_URL=https://kasugai.razornez.net
KASUGAI_SECRET_KEY=        # sk_... (WAJIB secret key, BUKAN pk_)
KASUGAI_WEBHOOK_SECRET=    # whsec_... (Signing Secret dari menu Webhook)

# --- Rahasia aplikasi -----------------------------------------
# Minimal 16 karakter. Gunakan nilai acak yang kuat di produksi.
SESSION_SECRET=change-me-dev-session-secret
APIKEY_HASH_PEPPER=change-me-dev-apikey-pepper

# --- Login Google (OAuth) — dipakai tahap auth ----------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email verifikasi -----------------------------------------
EMAIL_API_KEY=
EMAIL_FROM=

# --- Observability (opsional) ---------------------------------
SENTRY_DSN=

# --- i18n (docs/22) -------------------------------------------
# Fallback/basis tetap 'en'. Nilai default bila tidak terdeteksi.
DEFAULT_LOCALE=en
EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=noreply@docgen.razornez.net
