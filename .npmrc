# Workspace packages diakses lewat protokol workspace:* — jangan diam-diam ambil dari registry.
link-workspace-packages=true
# Cegah hoisting tak terduga; tiap paket hanya melihat dependensi yang ia deklarasikan.
auto-install-peers=true
strict-peer-dependencies=false
# Playwright mengunduh Chromium sendiri saat dipasang di worker (lihat docs/20).
