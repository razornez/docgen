{
  "name": "docgen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "build:all": "pnpm build && pnpm --filter @docgen/api run build && pnpm --filter @docgen/worker run build && pnpm --filter @docgen/dashboard run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @docgen/db run migrate",
    "qa:smoke": "tsx scripts/qa-smoke.ts",
    "qa:render": "tsx scripts/qa-render.ts",
    "dev:api": "pnpm --filter @docgen/api run dev",
    "dev:worker": "pnpm --filter @docgen/worker run dev",
    "dev:dashboard": "pnpm --filter @docgen/dashboard run dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
